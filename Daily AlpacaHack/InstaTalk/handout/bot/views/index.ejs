<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Report to Admin Bot</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>:root{color-scheme:dark;color:#eee}body{margin:0;background:#111;font-family:sans-serif}main{width:min(100% - 32px,960px);margin:0 auto;padding:48px 0}h1{text-align:center}form{display:flex}.prefix,input,button{padding:10px 12px;border:1px solid #456;font:inherit}.prefix{border-radius:6px 0 0 6px;background:#123;white-space:nowrap}input{min-width:0;flex:1;background:#111}button{border-radius:6px;background:#26e;color:#fff;cursor:pointer}</style>
  </head>
  <body>
    <main>
      <h1>Chat with Admin Bot</h1>
      <p>APP_URL: <code><%- APP_URL %></code></p>
      <form id="form">
        <button type="submit" id="report">Chat</button>
      </form>
      <p id="response"></p>
    </main>
    <script>
      const $response = document.getElementById("response");
      const $report = document.getElementById("report");

      document.getElementById("form").addEventListener("submit", async (event) => {
        event.preventDefault();

        try {
          $report.disabled = true;
          $response.textContent = "Response from bot: " + await(await fetch("/api/report", {
            method: "POST"
          })).text();
        } finally {
          $report.disabled = false;
        }
      });
    </script>
  </body>
</html>
