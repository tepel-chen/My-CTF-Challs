<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <style>
      :root {
        color-scheme: light;
        font-family: sans-serif;
      }
      body {
        margin: 0;
        background: #f4f1ea;
        color: #1d1d1d;
      }
      main {
        max-width: 640px;
        margin: 48px auto;
        padding: 24px;
        background: #fffaf2;
        border: 2px solid #1d1d1d;
        box-shadow: 8px 8px 0 #d6c8ad;
      }
      h1 {
        margin-top: 0;
      }
      .meta {
        margin: 0 0 20px;
        font-size: 14px;
        color: #555;
        word-break: break-all;
      }
      .meta a {
        color: inherit;
      }
      form {
        margin: 0;
      }
      .new-todo {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
      }
      input[type="text"] {
        flex: 1;
        padding: 12px;
        border: 2px solid #1d1d1d;
        font-size: 16px;
      }
      button {
        padding: 12px 16px;
        border: 2px solid #1d1d1d;
        background: #ffd166;
        cursor: pointer;
        font-weight: 700;
      }
      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      ul.todo-items li {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        border: 2px solid #1d1d1d;
        background: white;
      }
    </style>
  </head>
  <body>
    <main>
      <h1><%= pageTitle %></h1>
      <p class="meta">sessionId: <%= activeSessionId %></p>
      <% if (!isReadonly) { %>
        <p class="meta">
          readonly link:
          <a href="/?sessionId=<%= encodeURIComponent(activeSessionId) %>">
            /?sessionId=<%= activeSessionId %>
          </a>
        </p>
      <% } %>
      <% if (!isReadonly) { %>
        <form method="post" action="/todos" class="new-todo">
          <input type="text" name="title" maxlength="255" placeholder="Add a task" required />
          <button type="submit">Add</button>
        </form>
      <% } %>
      <ul class="todo-items">
        <% if (todos.length === 0) { %>
          <li>No tasks yet.</li>
        <% } %>
        <% todos.forEach((todo) => { %>
          <li>
            <%- todo %>
          </li>
        <% }) %>
      </ul>
    </main>
  </body>
</html>
